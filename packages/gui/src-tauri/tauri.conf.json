{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maker",
  "version": "0.1.0",
  "identifier": "com.equalinformation.maker",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "windows": [],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Build tools by conversation — on-device, offline.",
    "longDescription": "Maker builds runnable tools from a conversation, 100% on your device and offline. The AI-age successor to make.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/maker-server"],
    "resources": {
      "../web": "web",
      "../../../scripts/uninstall.command": "uninstall.command"
    }
  }
}
